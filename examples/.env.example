# =========================================================
# Monday Discord Relay
# Example Environment Configuration
# =========================================================

# ---------------------------------------------------------
# Core Service
# ---------------------------------------------------------

SERVICE_NAME=Monday Discord Relay

# ---------------------------------------------------------
# Discord Configuration
# ---------------------------------------------------------

# Discord webhook URL used for deployment notifications
DISCORD_WEBHOOK_URL=

# Optional fallback username
# If USE_BOARD_NAME_AS_WEBHOOK_USERNAME=true,
# the Monday board name becomes the webhook username
DISCORD_USERNAME=Monday Discord Relay

# Optional Discord role ping
# Example: 123456789012345678
DISCORD_ROLE_ID=

# ---------------------------------------------------------
# Monday.com Configuration
# ---------------------------------------------------------

# Monday API token
MONDAY_API_TOKEN=

# Group name that triggers deployment notifications
TARGET_GROUP_NAME=Ready for Deployment

# ---------------------------------------------------------
# Embed Configuration
# ---------------------------------------------------------

# Embed title
EMBED_TITLE=Deployment Readiness Confirmed

# Embed footer
EMBED_FOOTER=Development Pipeline • Monday Relay

# Embed status text
EMBED_STATUS=Ready for Deployment

# Discord embed color
# Decimal format only
EMBED_COLOR=4994733

# ---------------------------------------------------------
# Relay Behaviour
# ---------------------------------------------------------

# Enables extra debug information inside embeds
SHOW_DEBUG_FIELDS=false

# Enables /test-discord route
TEST_ROUTE_ENABLED=false

# Uses Monday board name as Discord webhook username
USE_BOARD_NAME_AS_WEBHOOK_USERNAME=true